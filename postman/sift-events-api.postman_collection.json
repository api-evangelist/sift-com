      "item": [
        {
          "name": "Sift Send Event",
          "id": "dc497f54-e8ed-4cfc-b950-dd88fa87ae79",
          "protocolProfileBehavior": {
            "disableBodyPruning": true
          },
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"$type\": \"$order_status\",\n  \"$api_key\": \"<string>\",\n  \"$user_id\": \"<string>\",\n  \"$session_id\": \"<string>\",\n  \"$ip\": \"<string>\",\n  \"$user_email\": \"<string>\",\n  \"$browser\": {},\n  \"$app\": {}\n}",
              "options": {
                "raw": {
                  "headerFamily": "json",
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/events?return_score=<boolean>&return_workflow_status=<boolean>&abuse_types=<string>",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "events"
              ],
              "query": [
                {
                  "description": "Return a synchronous Sift Score in the response.",
                  "key": "return_score",
                  "value": "<boolean>"
                },
                {
                  "description": "Return synchronous Workflow status in the response.",
                  "key": "return_workflow_status",
                  "value": "<boolean>"
                },
                {
                  "description": "Comma-separated abuse types (payment_abuse, content_abuse, account_takeover, account_abuse, promotion_abuse, legacy).",
                  "key": "abuse_types",
                  "value": "<string>"
                }
              ]
            },
            "description": "Submit an event to Sift for fraud and abuse scoring. The `$type` field selects\nthe reserved event type (for example, `$create_account`, `$create_order`,\n`$transaction`, `$login`, `$chargeback`, `$verification`). Pass\n`return_score=true` to receive a synchronous Sift Score in the response.\n"
