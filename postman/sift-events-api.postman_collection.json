  "info": {
    "_postman_id": "dc648bb1-d93b-4e7a-b593-36b849940776",
    "name": "Sift Events API",
    "description": "The Sift Events API is the primary integration point with the Sift Digital Trust\nand Safety platform. It records user, device, payment, content, and verification\nevents used to compute fraud risk scores in real time. Events can be submitted\nsynchronously to receive an immediate risk score and workflow status.\n\n\nContact Support:\n Name: Sift\n Email: support@sift.com",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "createdAt": "2026-06-05T15:17:33.000Z",
    "updatedAt": "2026-06-05T15:17:33.000Z",
    "lastUpdatedBy": "35240",
    "uid": "35240-dc648bb1-d93b-4e7a-b593-36b849940776"
  },
