  "info": {
    "_postman_id": "8d4bd02f-9633-4d8e-b5c0-11c0eba86ada",
    "name": "Sift Verification API",
    "description": "The Sift Verification API issues and validates one-time and knowledge-based\nverification challenges (SMS, email, phone, face, fingerprint, push, security\nkey) tied to a Sift user and parent event. Verification outcomes are persisted\non the user timeline and feed Sift's risk models.\n\n\nContact Support:\n Name: Sift\n Email: support@sift.com",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "createdAt": "2026-06-05T15:17:36.000Z",
    "updatedAt": "2026-06-05T15:17:36.000Z",
    "lastUpdatedBy": "35240",
    "uid": "35240-8d4bd02f-9633-4d8e-b5c0-11c0eba86ada"
  },
