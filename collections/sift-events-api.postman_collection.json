  "info": {
    "_postman_id": "caad2aef-61cd-4062-aac8-7637b00f6161",
    "name": "Sift Events API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The Sift Events API is the primary integration point with the Sift Digital Trust\nand Safety platform. It records user, device, payment, content, and verification\nevents used to compute fraud risk scores in real time. Events can be submitted\nsynchronously to receive an immediate risk score and workflow status.\n\n\nContact Support:\n Name: Sift\n Email: support@sift.com",
      "type": "text/plain"
    }
  }
