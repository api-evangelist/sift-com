      "name": "Events",
      "description": {
        "content": "Send fraud and abuse signals to Sift for scoring.",
        "type": "text/plain"
      },
      "item": [
        {
          "id": "b74bca8f-56ea-4b83-b287-743d8967580b",
          "name": "Sift Send Event",
          "request": {
            "name": "Sift Send Event",
            "description": {
              "content": "Submit an event to Sift for fraud and abuse scoring. The `$type` field selects\nthe reserved event type (for example, `$create_account`, `$create_order`,\n`$transaction`, `$login`, `$chargeback`, `$verification`). Pass\n`return_score=true` to receive a synchronous Sift Score in the response.\n",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "events"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "return_score",
                  "value": "<boolean>",
                  "description": "Return a synchronous Sift Score in the response."
                },
                {
                  "disabled": false,
                  "key": "return_workflow_status",
                  "value": "<boolean>",
                  "description": "Return synchronous Workflow status in the response."
                },
                {
                  "disabled": false,
                  "key": "abuse_types",
                  "value": "<string>",
                  "description": "Comma-separated abuse types (payment_abuse, content_abuse, account_takeover, account_abuse, promotion_abuse, legacy)."
                }
              ],
              "variable": []
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "POST",
            "auth": null,
            "body": {
              "mode": "raw",
              "raw": "{\n  \"$type\": \"<string>\",\n  \"$api_key\": \"<string>\",\n  \"$user_id\": \"<string>\",\n  \"$session_id\": \"<string>\",\n  \"$ip\": \"<string>\",\n  \"$user_email\": \"<string>\",\n  \"$browser\": \"<object>\",\n  \"$app\": \"<object>\"\n}",
